# environments/staging/versions.tf
# Identical version constraints as dev — all environments must use the same provider version
# This ensures plan output is consistent across environments

terraform {
  required_version = ">= 1.6.0, < 2.0.0"

  required_providers {
    google = {
      source  = "hashicorp/google"
      version = "~> 5.0"
    }
    google-beta = {
      source  = "hashicorp/google-beta"
      version = "~> 5.0"
    }
  }
}