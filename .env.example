# Google Cloud Credentials
# ── 通用（gcloud CLI + Go/Python SDK 均适用） ──

# 服务账号 JSON 密钥文件路径（推荐，同时兼容 CLI 和 SDK）
# gcloud CLI: 自动读取本变量
# Go SDK (cloud.google.com/go): 通过 option.WithCredentialsFile() 读取
# Python SDK (google-cloud-*): 通过 os.Getenv 读取
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account-key.json

# GCP 项目 ID（CLI + SDK 均使用）
CLOUDSDK_CORE_PROJECT=your-gcp-project-id

┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅
# ── gcloud CLI 专属 ──
# ── 仅在需要覆盖 SDK 默认行为时设置 ──
┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅

# 默认计算引擎可用区/地域（为需要 zone/region 的命令提供默认值）
CLOUDSDK_COMPUTE_ZONE=us-central1-f
CLOUDSDK_COMPUTE_REGION=us-central1

# 预先获取的访问令牌（替代 GOOGLE_APPLICATION_CREDENTIALS）
# gcloud auth application-default print-access-token
# CLOUDSDK_AUTH_ACCESS_TOKEN=ya29...

# gcloud CLI 配置路径（默认 ~/.config/gcloud）
# CLOUDSDK_CONFIG=/custom/path/to/gcloud/config

┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅
# ── Go SDK 专属 (cloud.google.com/go) ──
# ── JIT 脚本用，snippet 无需手动设置，由 env 自动传递 ──
┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅

# Go SDK 通常通过 GOOGLE_APPLICATION_CREDENTIALS + oauth2 直接认证
# 以下变量用于显式指定 project / zone（对应 gcloud 变量名，SDK 也读取）
# 已在上面 CLOUDSDK_CORE_PROJECT / CLOUDSDK_COMPUTE_ZONE 设置

┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅
# ── 其它常用 GCP 工具配置 ──
┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅

# Terraform 后端（GCS）
# TF_VAR_project_id=${CLOUDSDK_CORE_PROJECT}
# TF_BACKEND_BUCKET=terraform-state-${CLOUDSDK_CORE_PROJECT}

# Kubernetes / GKE（gcloud auth plugin 会通过 GOOGLE_APPLICATION_CREDENTIALS 自动获取令牌）
# KUBECONFIG=/path/to/kubeconfig

┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅
# ── 多项目 / 多账号配置（可选） ──
# ── 当需要同时操作多个 GCP 项目时使用 ──
┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅

# 方案 A: 覆盖当前 shell session 的 project
# export CLOUDSDK_CORE_PROJECT=another-project-id
# export GOOGLE_APPLICATION_CREDENTIALS=/path/to/another-sa-key.json

# 方案 B: 使用 gcloud config configurations（不影响本 env）
# gcloud config configurations create my-other-project
# gcloud config set project another-project-id --configuration=my-other-project
# gcloud config configurations activate my-other-project

┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅
# ── 安全提醒 (SECURITY WARNING) ──
# ── 严禁将此文件提交到版本控制系统 ──
# ── .env 已在 .gitignore 中 ──
# ── 生成的 Skill 中始终使用 {{env.*}} 占位符，不写入实际值 ──
┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅┅

# 🔴 不要：
# - 将真实的 SA 密钥 JSON 内容写入 .env
# - 将 .env 提交到 git
# - 在日志或输出中 echo/cat $GOOGLE_APPLICATION_CREDENTIALS

# 🟢 应做：
# - 检查存在性：test -f "$GOOGLE_APPLICATION_CREDENTIALS"
# - 在日志中遮盖：GOOGLE_APPLICATION_CREDENTIALS=<masked>